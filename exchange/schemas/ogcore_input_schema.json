{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OGCoreInputSchema",
  "description": "Exchange file from CLEWS to OG-Core. Parameter names verified against ogcore/default_parameters.json.",
  "type": "object",
  "required": [
    "version",
    "scenario",
    "parameters"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "scenario": {
      "type": "string"
    },
    "ogcore_param_source": {
      "type": "string"
    },
    "parameters": {
      "type": "object",
      "required": [
        "Z",
        "tau_c",
        "alpha_T",
        "inv_tax_credit",
        "g_y_annual"
      ],
      "properties": {
        "Z": {
          "description": "Total factor productivity in firm production function. Shape (T+S, M). Source: TotalAnnualTechnologyActivityByMode normalized to base-year index.",
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "year",
              "value"
            ],
            "properties": {
              "year": {
                "type": "integer"
              },
              "value": {
                "type": "number",
                "minimum": 0
              }
            }
          }
        },
        "tau_c": {
          "description": "Consumption tax rate on energy good i. Shape (T+S, I). Source: AnnualEmissions x carbon_price / GDP. energy_good_index specifies which consumption good in OG-Core's I-vector.",
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "year",
              "energy_good_index",
              "value"
            ],
            "properties": {
              "year": {
                "type": "integer"
              },
              "energy_good_index": {
                "type": "integer",
                "minimum": 0
              },
              "value": {
                "type": "number",
                "minimum": 0
              }
            }
          }
        },
        "alpha_T": {
          "description": "Exogenous ratio of government transfers to GDP. Shape (T+S,). Source: TotalDiscountedCost / GDP_reference.",
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "year",
              "value"
            ],
            "properties": {
              "year": {
                "type": "integer"
              },
              "value": {
                "type": "number",
                "minimum": 0
              }
            }
          }
        },
        "inv_tax_credit": {
          "description": "Investment tax credit rate — reduces cost of new investment. Shape (T+S, M). Source: ProductionByTechnology renewable share of total production.",
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "year",
              "value"
            ],
            "properties": {
              "year": {
                "type": "integer"
              },
              "value": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              }
            }
          }
        },
        "g_y_annual": {
          "description": "Annual growth rate of labor-augmenting technological change. Scalar float. OG-Core converts internally via rate_conversion(g_y_annual, starting_age, ending_age, S). Source: TotalCapacityAnnual year-on-year growth.",
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "year",
              "value"
            ],
            "properties": {
              "year": {
                "type": "integer"
              },
              "value": {
                "type": "number",
                "minimum": -0.01,
                "maximum": 0.08
              }
            }
          }
        }
      }
    }
  }
}